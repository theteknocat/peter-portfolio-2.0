#!/bin/bash

# Conventional Commits commit-msg hook
# Validates that commit messages follow the conventional commits format.
# https://www.conventionalcommits.org/

commit_msg_file="$1"
commit_msg=$(head -1 "$commit_msg_file")

# Allow merge commits and revert commits generated by git
if echo "$commit_msg" | grep -qE "^Merge "; then
    exit 0
fi

# Allow fixup and squash commits (used during interactive rebase)
if echo "$commit_msg" | grep -qE "^(fixup|squash)! "; then
    exit 0
fi

errors=()
max_length=100

# Validate conventional commit format
if ! echo "$commit_msg" | grep -qE "^(feat|fix|improv|docs|style|refactor|perf|test|build|ci|chore|revert)(\(.+\))?(!)?: .{1,}$"; then
    errors+=("Commit message does not follow Conventional Commits format.
  Expected: type(scope)?: description

  Valid types: feat fix improv docs style refactor perf test build ci chore revert

  Examples:
    feat: add dark mode toggle
    fix(auth): handle expired sessions
    chore: update dependencies
    feat!: redesign API  (breaking change)")
fi

# Validate first line length
if [ ${#commit_msg} -gt $max_length ]; then
    errors+=("First line is ${#commit_msg} characters (max $max_length).
  Keep the subject line concise. Use an extended body for details.")
fi

# Validate blank line before body and body line lengths
line_num=0
second_line=""
long_lines=""
while IFS= read -r line; do
    line_num=$((line_num + 1))
    if [ "$line_num" -eq 2 ]; then
        second_line="$line"
    elif [ "$line_num" -gt 2 ] && [ -n "$line" ] && [ ${#line} -gt $max_length ]; then
        if [ -n "$long_lines" ]; then
            long_lines="$long_lines,$line_num"
        else
            long_lines="$line_num"
        fi
    fi
done < "$commit_msg_file"

if [ "$line_num" -gt 1 ] && [ -n "$second_line" ]; then
    errors+=("Missing blank line between subject and body.
  Add an empty line after the first line before the extended description.")
fi

if [ -n "$long_lines" ]; then
    errors+=("Body line(s) $long_lines exceed $max_length characters.
  Wrap long lines or use bullet points.")
fi

# Report all errors at once
if [ ${#errors[@]} -gt 0 ]; then
    echo ""
    for i in "${!errors[@]}"; do
        echo "ERROR $((i + 1)): ${errors[$i]}"
        echo ""
    done
    exit 1
fi

exit 0

APP_ENV=production

# Clippy quip generation (see src/Services/ClippyService.php)
# Anthropic API key — required for Clippy to generate quips; without it the
# frontend falls back to its built-in lines.
ANTHROPIC_API_KEY=
# Model used to generate quips. Defaults to claude-haiku-4-5 if unset.
CLIPPY_MODEL=claude-haiku-4-5
# How long (seconds) a cached quip pool stays fresh. Defaults to 604800 (7 days).
CLIPPY_CACHE_TTL=604800
